# ---- Server-side (Netlify Functions) : NEVER exposed to the browser ----
# From the Spotify dashboard app (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# The shared playlist the site reads/writes (id only, e.g. 37i9dQZF1DXcBWIGoYBM5M)
SPOTIFY_PLAYLIST_ID=
# Owner refresh token — mint once with: npm run token
SPOTIFY_REFRESH_TOKEN=

# ---- Client-side (Vite) : public, safe to expose ----
# Same client id as above; needed for the in-browser PKCE listener login.
VITE_SPOTIFY_CLIENT_ID=
